# ─────────────────────────────────────────────────────────────
# Ágora — variables de entorno (plantilla). Copia a .env y rellena.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────

# App
ENV=development                       # development | production
APP_NAME=Agora
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Seguridad / sesión (Fase 1)
# Genera con: openssl rand -hex 32
SECRET_KEY=change-me-dev-secret-0123456789abcdef0123456789abcdef0123456789ab
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=agora_session
SESSION_COOKIE_SECURE=false           # true en producción (HTTPS)
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=604800        # 7 días

# Base de datos (Postgres + pgvector)
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora
POSTGRES_DB=agora
POSTGRES_PORT=5432
# DSN async que usa la app. 'db' = nombre del servicio en docker-compose.
DATABASE_URL=postgresql+asyncpg://agora:agora@db:5432/agora

# Google OAuth — login (Fase 1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
GOOGLE_ALLOWED_HD=invesa.com          # restringe el login al dominio de Invesa

# Administradores iniciales (se siembran como admin global). Separados por coma.
BOOTSTRAP_ADMIN_EMAILS=admin@invesa.com

# ── Fases futuras (documentado; se activa al llegar la fase) ──────────

# Gemini (Fases 4–5)
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# GitHub App (Fase 2)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=             # contenido PEM o ruta montada
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_WEBHOOK_SECRET=

# Google Workspace — scopes de escritura + tokens cifrados (Fase 3+)
# Clave Fernet para cifrar oauth_tokens en reposo. Genera con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TOKEN_ENCRYPTION_KEY=

# Notificaciones (Fase 6) — correo como plataforma (SMTP) o como usuario (Gmail API)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SLACK_BOT_TOKEN=
# SLACK_WEBHOOK_URL=

# n8n (Fase 6) — perfil 'tools' en docker-compose
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=change-me
# GENERIC_TIMEZONE=UTC
