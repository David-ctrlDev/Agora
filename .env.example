# ─────────────────────────────────────────────────────────────
# Ágora — variables de entorno (plantilla). Copia a .env y ajusta.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────

# App
ENV=development                       # development | production
APP_NAME=Agora
BACKEND_PORT=8000
FRONTEND_PORT=5173
# En desarrollo el backend aplica migraciones y siembra datos al arrancar.
SEED_ON_START=true

# Seguridad / sesión
# Genera con: openssl rand -hex 32   (mínimo 32 bytes)
SECRET_KEY=change-me-dev-secret-0123456789abcdef0123456789abcdef0123456789ab
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=agora_session
SESSION_COOKIE_SECURE=false           # true en producción (HTTPS)
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=604800        # 7 días

# Base de datos (Postgres + pgvector)
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora
POSTGRES_DB=agora
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://agora:agora@db:5432/agora

# Proveedores de integración: "mock" (determinista, sin red) o "real" (con credenciales).
GITHUB_PROVIDER=mock
GOOGLE_PROVIDER=mock
GEMINI_PROVIDER=mock

# Login con Google (Fase 3, proveedor real). Con el login de desarrollo no se requieren.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
GOOGLE_ALLOWED_HD=invesa.com          # restringe el login al dominio de Invesa
# Super administradores globales (ven y gestionan todo). Fijados por config. Coma-separado.
SUPERADMIN_EMAILS=wserna@invesa.com
BOOTSTRAP_ADMIN_EMAILS=wserna@invesa.com

# GitHub (Fase 2). El webhook entrante se verifica con este secreto (HMAC).
GITHUB_WEBHOOK_SECRET=dev-webhook-secret
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=             # contenido PEM o ruta montada
# GITHUB_APP_INSTALLATION_ID=

# Gemini (Fases 4–5, proveedor real). Con el proveedor mock no se requieren.
# GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Cifrado de tokens OAuth en reposo (Fernet). Vacío => clave derivada de SECRET_KEY (solo dev).
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TOKEN_ENCRYPTION_KEY=

# Notificaciones (Fase 6) — token para que n8n dispare POST /api/notifications/run
NOTIFICATIONS_RUN_TOKEN=dev-run-token

# n8n (perfil 'tools' de docker-compose)
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=change-me
# GENERIC_TIMEZONE=UTC

# Slack (opcional, fase 6)
# SLACK_BOT_TOKEN=
# SLACK_WEBHOOK_URL=
