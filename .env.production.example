# ============================================================
# Plantilla del .env de PRODUCCIÓN. Copia esto a `.env` EN EL SERVIDOR
# (DEPLOY_PATH/.env) y rellena los secretos reales. NUNCA se sube desde local.
#   cp .env.production.example .env   # en el servidor, y editar
#
# DOS FASES (importante):
#   FASE 1 — solo red interna por IP, sin dominio ni TLS: deja
#     SESSION_COOKIE_SECURE=false. OJO: el login con Google NO funciona sobre IP
#     (Google exige https + dominio en el redirect). Esta fase es para validar el
#     stack, no para abrir a usuarios.
#   FASE 2 — cuando infra dé dominio + WAF/HTTPS: pon SESSION_COOKIE_SECURE=true,
#     ajusta GOOGLE_OAUTH_REDIRECT_URI al dominio real y regístralo en Google Cloud.
#     Recién aquí los usuarios entran con Google.
# ============================================================
ENV=production
APP_NAME=Agora
SEED_ON_START=false

# Puerto del host donde se publica el frontend (nginx de Ágora). Usa 8090 (u otro)
# si otra app (p. ej. Analityx) ya ocupa el :80 del servidor.
FRONTEND_PORT=8090

# --- Seguridad / sesión (genera valores fuertes y únicos) ---
SECRET_KEY=__CAMBIAR__genera_uno_largo_aleatorio_de_64_hex__
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=agora_session
SESSION_COOKIE_SECURE=false           # FASE 1 (IP/HTTP): false · FASE 2 (dominio/HTTPS): true
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=604800
# Clave Fernet para cifrar tokens OAuth en reposo (genera una real):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=__CAMBIAR__clave_fernet_base64__

# --- Base de datos (debe coincidir con DB_USER/DB_NAME del deploy.sh) ---
POSTGRES_USER=agora
POSTGRES_PASSWORD=__CAMBIAR__password_fuerte__
POSTGRES_DB=agora
DATABASE_URL=postgresql+asyncpg://agora:__CAMBIAR__password_fuerte__@db:5432/agora

# --- Proveedores reales en producción ---
GITHUB_PROVIDER=mock                  # o real, si se usa GitHub App
GOOGLE_PROVIDER=real
GEMINI_PROVIDER=real

# --- Google OAuth (credenciales reales + dominio de prod) ---
# FASE 2: el redirect DEBE ser https + dominio (Google no admite IPs). Debe coincidir
# EXACTO con el "Authorized redirect URI" registrado en Google Cloud Console.
GOOGLE_CLIENT_ID=__CAMBIAR__
GOOGLE_CLIENT_SECRET=__CAMBIAR__
GOOGLE_OAUTH_REDIRECT_URI=https://TU-DOMINIO/api/auth/google/callback
GOOGLE_ALLOWED_HD=invesa.com
# Auto-provisión: cualquier cuenta de GOOGLE_ALLOWED_HD entra (se crea como member en
# el primer login). Pon false para volver a lista blanca (solo usuarios ya creados).
GOOGLE_AUTO_PROVISION=true
# Super administradores globales (ven y gestionan todo). Fijados por config. Coma-separado.
SUPERADMIN_EMAILS=wserna@invesa.com
BOOTSTRAP_ADMIN_EMAILS=wserna@invesa.com

# --- Gemini ---
GEMINI_API_KEY=__CAMBIAR__
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Documentación en Drive (espejo) ---
DRIVE_DOCS_ENABLED=true

# --- Otros ---
GITHUB_WEBHOOK_SECRET=__CAMBIAR__
NOTIFICATIONS_RUN_TOKEN=__CAMBIAR__
APP_UTC_OFFSET_HOURS=-5
