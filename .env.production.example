# ============================================================
# Plantilla del .env de PRODUCCIÓN. Copia esto a `.env` EN EL SERVIDOR
# (DEPLOY_PATH/.env) y rellena los secretos reales. NUNCA se sube desde local.
#   cp .env.production.example .env   # en el servidor, y editar
# ============================================================
ENV=production
APP_NAME=Agora
SEED_ON_START=false

# --- Seguridad / sesión (genera valores fuertes y únicos) ---
SECRET_KEY=__CAMBIAR__genera_uno_largo_aleatorio_de_64_hex__
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=agora_session
SESSION_COOKIE_SECURE=true            # requiere HTTPS
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=604800
# Clave Fernet para cifrar tokens OAuth en reposo (genera una real):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=__CAMBIAR__clave_fernet_base64__

# --- Base de datos (debe coincidir con DB_USER/DB_NAME del deploy.sh) ---
POSTGRES_USER=agora
POSTGRES_PASSWORD=__CAMBIAR__password_fuerte__
POSTGRES_DB=agora
DATABASE_URL=postgresql+asyncpg://agora:__CAMBIAR__password_fuerte__@db:5432/agora

# --- Proveedores reales en producción ---
GITHUB_PROVIDER=mock                  # o real, si se usa GitHub App
GOOGLE_PROVIDER=real
GEMINI_PROVIDER=real

# --- Google OAuth (credenciales reales + dominio de prod) ---
GOOGLE_CLIENT_ID=__CAMBIAR__
GOOGLE_CLIENT_SECRET=__CAMBIAR__
GOOGLE_OAUTH_REDIRECT_URI=https://TU-DOMINIO/api/auth/google/callback
GOOGLE_ALLOWED_HD=invesa.com
BOOTSTRAP_ADMIN_EMAILS=wserna@invesa.com

# --- Gemini ---
GEMINI_API_KEY=__CAMBIAR__
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Documentación en Drive (espejo) ---
DRIVE_DOCS_ENABLED=true

# --- Otros ---
GITHUB_WEBHOOK_SECRET=__CAMBIAR__
NOTIFICATIONS_RUN_TOKEN=__CAMBIAR__
APP_UTC_OFFSET_HOURS=-5
